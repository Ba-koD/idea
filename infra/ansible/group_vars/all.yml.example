platform_admin_user: ubuntu
platform_container_runtime: docker
idea_base_domain: idea.example.internal
kind_cluster_name: idea
kind_node_image: kindest/node:v1.30.0
kind_version: v0.23.0
kubectl_version: v1.30.3
helm_version: v3.15.4
argocd_version: v2.11.7
enable_monitoring: true
enable_vault: true
enable_cloudflared: false
enable_cloudflare_reconciliation: false
cloudflared_tunnel_token: ""
cloudflare_api_token: ""
cloudflare_account_id: ""
cloudflare_zone_id: ""
cloudflare_public_subdomain: idea
cloudflare_tunnel_name: idea-platform
cloudflare_admin_allowed_ips: []
platform_caddy_backend_base_path: /api
idea_namespace: idea-system
edge_namespace: edge-system
monitoring_namespace: monitoring
data_namespace: idea-data
vault_namespace: vault
gitops_repo_url: https://github.com/your-org/idea.git
gitops_repo_branch: main
gitops_repo_path: gitops/idea-platform/workloads
gitops_repo_username: x-access-token
gitops_repo_token: ""
postgresql_password: replace-me-postgres
vault_dev_root_token: replace-me-vault-root
