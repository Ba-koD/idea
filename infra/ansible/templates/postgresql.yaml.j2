apiVersion: v1
kind: Secret
metadata:
  name: {{ postgresql_release_name }}-auth
  namespace: {{ data_namespace }}
type: Opaque
stringData:
  POSTGRES_USER: {{ postgresql_username }}
  POSTGRES_PASSWORD: {{ postgresql_password }}
  POSTGRES_DB: {{ postgresql_database }}
---
apiVersion: v1
kind: PersistentVolumeClaim
metadata:
  name: {{ postgresql_release_name }}-data
  namespace: {{ data_namespace }}
spec:
  accessModes:
    - ReadWriteOnce
  resources:
    requests:
      storage: {{ postgresql_storage_size }}
---
apiVersion: v1
kind: Service
metadata:
  name: {{ postgresql_release_name }}
  namespace: {{ data_namespace }}
spec:
  selector:
    app.kubernetes.io/name: {{ postgresql_release_name }}
  ports:
    - name: postgres
      port: 5432
      targetPort: 5432
---
apiVersion: apps/v1
kind: Deployment
metadata:
  name: {{ postgresql_release_name }}
  namespace: {{ data_namespace }}
spec:
  replicas: 1
  selector:
    matchLabels:
      app.kubernetes.io/name: {{ postgresql_release_name }}
  template:
    metadata:
      labels:
        app.kubernetes.io/name: {{ postgresql_release_name }}
    spec:
      containers:
        - name: postgresql
          image: {{ postgresql_image_repository }}:{{ postgresql_image_tag }}
          imagePullPolicy: IfNotPresent
          ports:
            - containerPort: 5432
              name: postgres
          envFrom:
            - secretRef:
                name: {{ postgresql_release_name }}-auth
          env:
            - name: PGDATA
              value: /var/lib/postgresql/data/pgdata
          readinessProbe:
            exec:
              command:
                - sh
                - -c
                - pg_isready -U "$POSTGRES_USER" -d "$POSTGRES_DB" -h 127.0.0.1 -p 5432
            initialDelaySeconds: 5
            periodSeconds: 10
            timeoutSeconds: 5
          livenessProbe:
            exec:
              command:
                - sh
                - -c
                - pg_isready -U "$POSTGRES_USER" -d "$POSTGRES_DB" -h 127.0.0.1 -p 5432
            initialDelaySeconds: 30
            periodSeconds: 10
            timeoutSeconds: 5
          volumeMounts:
            - name: postgres-data
              mountPath: /var/lib/postgresql/data
      volumes:
        - name: postgres-data
          persistentVolumeClaim:
            claimName: {{ postgresql_release_name }}-data
