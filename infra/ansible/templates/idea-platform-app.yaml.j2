apiVersion: apps/v1
kind: Deployment
metadata:
  name: {{ idea_frontend_name }}
  namespace: {{ idea_namespace }}
  labels:
    app.kubernetes.io/instance: idea-platform
spec:
  replicas: {{ idea_frontend_replicas }}
  selector:
    matchLabels:
      app: {{ idea_frontend_name }}
  template:
    metadata:
      labels:
        app: {{ idea_frontend_name }}
        app.kubernetes.io/instance: idea-platform
    spec:
      containers:
        - name: frontend
          image: {{ idea_frontend_image }}
          imagePullPolicy: IfNotPresent
          ports:
            - containerPort: {{ idea_frontend_container_port }}
              name: http
          readinessProbe:
            httpGet:
              path: /
              port: http
            initialDelaySeconds: 5
            periodSeconds: 10
          livenessProbe:
            httpGet:
              path: /
              port: http
            initialDelaySeconds: 15
            periodSeconds: 20
---
apiVersion: v1
kind: ServiceAccount
metadata:
  name: {{ idea_backend_name }}-control-plane
  namespace: {{ idea_namespace }}
  labels:
    app.kubernetes.io/instance: idea-platform
---
apiVersion: v1
kind: Secret
metadata:
  name: {{ idea_backend_name }}-control-plane-secrets
  namespace: {{ idea_namespace }}
  labels:
    app.kubernetes.io/instance: idea-platform
type: Opaque
stringData:
  app_repo_token: "{{ app_repo_token }}"
  gitops_repo_token: "{{ gitops_repo_token }}"
---
apiVersion: rbac.authorization.k8s.io/v1
kind: Role
metadata:
  name: {{ idea_backend_name }}-argocd-secret-writer
  namespace: argocd
  labels:
    app.kubernetes.io/instance: idea-platform
rules:
  - apiGroups: [""]
    resources: ["secrets"]
    verbs: ["get", "list", "create", "patch", "update", "delete"]
  - apiGroups: ["apps"]
    resources: ["deployments"]
    verbs: ["get", "list", "patch", "update"]
  - apiGroups: ["argoproj.io"]
    resources: ["applications"]
    verbs: ["get", "list", "create", "patch", "update"]
---
apiVersion: rbac.authorization.k8s.io/v1
kind: RoleBinding
metadata:
  name: {{ idea_backend_name }}-argocd-secret-writer
  namespace: argocd
  labels:
    app.kubernetes.io/instance: idea-platform
subjects:
  - kind: ServiceAccount
    name: {{ idea_backend_name }}-control-plane
    namespace: {{ idea_namespace }}
roleRef:
  apiGroup: rbac.authorization.k8s.io
  kind: Role
  name: {{ idea_backend_name }}-argocd-secret-writer
---
apiVersion: v1
kind: Service
metadata:
  name: {{ idea_frontend_name }}
  namespace: {{ idea_namespace }}
  labels:
    app.kubernetes.io/instance: idea-platform
spec:
  selector:
    app: {{ idea_frontend_name }}
  ports:
    - name: http
      port: {{ idea_frontend_service_port }}
      targetPort: http
  type: ClusterIP
---
apiVersion: v1
kind: PersistentVolumeClaim
metadata:
  name: {{ idea_backend_name }}-state
  namespace: {{ idea_namespace }}
  labels:
    app.kubernetes.io/instance: idea-platform
spec:
  accessModes:
    - ReadWriteOnce
  resources:
    requests:
      storage: {{ idea_backend_state_storage_size }}
  storageClassName: {{ idea_backend_state_storage_class }}
---
apiVersion: apps/v1
kind: Deployment
metadata:
  name: {{ idea_backend_name }}
  namespace: {{ idea_namespace }}
  labels:
    app.kubernetes.io/instance: idea-platform
spec:
  strategy:
    type: Recreate
  replicas: {{ idea_backend_replicas }}
  selector:
    matchLabels:
      app: {{ idea_backend_name }}
  template:
    metadata:
      labels:
        app: {{ idea_backend_name }}
        app.kubernetes.io/instance: idea-platform
    spec:
      serviceAccountName: {{ idea_backend_name }}-control-plane
      containers:
        - name: backend
          image: {{ idea_backend_image }}
          imagePullPolicy: IfNotPresent
          env:
            - name: PORT
              value: "{{ idea_backend_container_port }}"
            - name: APP_ENV
              value: "platform"
            - name: IDEA_SECRET_GITHUB_REPO_EXAMPLE_TOKEN
              valueFrom:
                secretKeyRef:
                  name: {{ idea_backend_name }}-control-plane-secrets
                  key: app_repo_token
            - name: GITHUB_REPO_EXAMPLE_TOKEN
              valueFrom:
                secretKeyRef:
                  name: {{ idea_backend_name }}-control-plane-secrets
                  key: app_repo_token
            - name: IDEA_SECRET_GITOPS_REPO_TOKEN
              valueFrom:
                secretKeyRef:
                  name: {{ idea_backend_name }}-control-plane-secrets
                  key: gitops_repo_token
            - name: GITOPS_REPO_TOKEN
              valueFrom:
                secretKeyRef:
                  name: {{ idea_backend_name }}-control-plane-secrets
                  key: gitops_repo_token
            - name: IDEA_STATE_DB_PATH
              value: "{{ idea_backend_state_db_path }}"
            - name: IDEA_STATE_ENCRYPTION_KEY_PATH
              value: "{{ idea_backend_state_key_path }}"
          ports:
            - containerPort: {{ idea_backend_container_port }}
              name: http
          volumeMounts:
            - name: backend-state
              mountPath: {{ idea_backend_state_mount_path }}
          readinessProbe:
            httpGet:
              path: {{ platform_caddy_backend_base_path }}/readyz
              port: http
            initialDelaySeconds: 5
            periodSeconds: 10
          livenessProbe:
            httpGet:
              path: {{ platform_caddy_backend_base_path }}/healthz
              port: http
            initialDelaySeconds: 15
            periodSeconds: 20
      volumes:
        - name: backend-state
          persistentVolumeClaim:
            claimName: {{ idea_backend_name }}-state
---
apiVersion: v1
kind: Service
metadata:
  name: {{ idea_backend_name }}
  namespace: {{ idea_namespace }}
  labels:
    app.kubernetes.io/instance: idea-platform
spec:
  selector:
    app: {{ idea_backend_name }}
  ports:
    - name: http
      port: {{ idea_backend_service_port }}
      targetPort: http
  type: ClusterIP
