apiVersion: apps/v1
kind: Deployment
metadata:
  name: {{ idea_frontend_name }}
  namespace: {{ idea_namespace }}
  labels:
    app.kubernetes.io/instance: idea-platform
spec:
  replicas: {{ idea_frontend_replicas }}
  selector:
    matchLabels:
      app: {{ idea_frontend_name }}
  template:
    metadata:
      labels:
        app: {{ idea_frontend_name }}
        app.kubernetes.io/instance: idea-platform
    spec:
      containers:
        - name: frontend
          image: {{ idea_frontend_image }}
          imagePullPolicy: IfNotPresent
          ports:
            - containerPort: {{ idea_frontend_container_port }}
              name: http
          readinessProbe:
            httpGet:
              path: /
              port: http
            initialDelaySeconds: 5
            periodSeconds: 10
          livenessProbe:
            httpGet:
              path: /
              port: http
            initialDelaySeconds: 15
            periodSeconds: 20
---
apiVersion: v1
kind: Service
metadata:
  name: {{ idea_frontend_name }}
  namespace: {{ idea_namespace }}
  labels:
    app.kubernetes.io/instance: idea-platform
spec:
  selector:
    app: {{ idea_frontend_name }}
  ports:
    - name: http
      port: {{ idea_frontend_service_port }}
      targetPort: http
  type: ClusterIP
---
apiVersion: apps/v1
kind: Deployment
metadata:
  name: {{ idea_backend_name }}
  namespace: {{ idea_namespace }}
  labels:
    app.kubernetes.io/instance: idea-platform
spec:
  replicas: {{ idea_backend_replicas }}
  selector:
    matchLabels:
      app: {{ idea_backend_name }}
  template:
    metadata:
      labels:
        app: {{ idea_backend_name }}
        app.kubernetes.io/instance: idea-platform
    spec:
      containers:
        - name: backend
          image: {{ idea_backend_image }}
          imagePullPolicy: IfNotPresent
          env:
            - name: PORT
              value: "{{ idea_backend_container_port }}"
            - name: APP_ENV
              value: "platform"
          ports:
            - containerPort: {{ idea_backend_container_port }}
              name: http
          readinessProbe:
            httpGet:
              path: {{ platform_caddy_backend_base_path }}/readyz
              port: http
            initialDelaySeconds: 5
            periodSeconds: 10
          livenessProbe:
            httpGet:
              path: {{ platform_caddy_backend_base_path }}/healthz
              port: http
            initialDelaySeconds: 15
            periodSeconds: 20
---
apiVersion: v1
kind: Service
metadata:
  name: {{ idea_backend_name }}
  namespace: {{ idea_namespace }}
  labels:
    app.kubernetes.io/instance: idea-platform
spec:
  selector:
    app: {{ idea_backend_name }}
  ports:
    - name: http
      port: {{ idea_backend_service_port }}
      targetPort: http
  type: ClusterIP
