apiVersion: v1
kind: Namespace
metadata:
  name: __IDEA_NAMESPACE__
---
apiVersion: v1
kind: ConfigMap
metadata:
  name: idea-config
  namespace: __IDEA_NAMESPACE__
data:
  __ENV_VARS__
---
apiVersion: apps/v1
kind: Deployment
metadata:
  name: idea-frontend
  namespace: __IDEA_NAMESPACE__
spec:
  replicas: 1
  selector:
    matchLabels:
      app: idea-frontend
  template:
    metadata:
      labels:
        app: idea-frontend
    spec:
      containers:
        - name: frontend
          image: __FRONTEND_IMAGE__
          imagePullPolicy: IfNotPresent
          ports:
            - containerPort: 80
              name: http
          readinessProbe:
            httpGet:
              path: /
              port: http
            initialDelaySeconds: 5
            periodSeconds: 10
          livenessProbe:
            httpGet:
              path: /
              port: http
            initialDelaySeconds: 15
            periodSeconds: 20
---
apiVersion: v1
kind: Service
metadata:
  name: idea-frontend
  namespace: __IDEA_NAMESPACE__
spec:
  selector:
    app: idea-frontend
  ports:
    - name: http
      port: 80
      targetPort: http
  type: ClusterIP
---
apiVersion: apps/v1
kind: Deployment
metadata:
  name: idea-backend
  namespace: __IDEA_NAMESPACE__
spec:
  replicas: 1
  selector:
    matchLabels:
      app: idea-backend
  template:
    metadata:
      labels:
        app: idea-backend
    spec:
      containers:
        - name: backend
          image: __BACKEND_IMAGE__
          imagePullPolicy: IfNotPresent
          ports:
            - containerPort: 8080
              name: http
          envFrom:
            - configMapRef:
                name: idea-config
          env:
            - name: HTTP_PORT
              value: "8080"
            - name: HTTP_RESPONSE
              value: '{"status":"ok","service":"idea-backend"}'
          readinessProbe:
            httpGet:
              path: __BACKEND_BASE_PATH__/readyz
              port: http
            initialDelaySeconds: 5
            periodSeconds: 10
          livenessProbe:
            httpGet:
              path: __BACKEND_BASE_PATH__/healthz
              port: http
            initialDelaySeconds: 15
            periodSeconds: 20
---
apiVersion: v1
kind: Service
metadata:
  name: idea-backend
  namespace: __IDEA_NAMESPACE__
spec:
  selector:
    app: idea-backend
  ports:
    - name: http
      port: 8080
      targetPort: http
  type: ClusterIP