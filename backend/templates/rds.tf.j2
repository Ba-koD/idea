resource "aws_db_instance" "default" {
  allocated_storage    = 10
  db_name              = "mydb"
  engine               = "mysql"
  engine_version       = "8.0"
  instance_class       = "db.t3.micro"
  username             = "admin"
  password             = "password123!" # 실제 서비스에선 변수처리가 필요합니다
  skip_final_snapshot  = true
  db_subnet_group_name = "default"
}
