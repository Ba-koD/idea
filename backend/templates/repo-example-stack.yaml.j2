apiVersion: v1
kind: ConfigMap
metadata:
  name: {{ project.name }}-{{ selected_env }}-frontend-assets
  namespace: {{ target.namespace }}
  labels:
    idea.rnen.kr/project: {{ project.name }}
    idea.rnen.kr/environment: {{ selected_env }}
data:
  index.html: |
{% for line in frontend_index_html.split('\n') %}
    {{ line }}
{% endfor %}
  app.js: |
{% for line in frontend_app_js.split('\n') %}
    {{ line }}
{% endfor %}
  config.js.template: |
{% for line in frontend_config_js_template.split('\n') %}
    {{ line }}
{% endfor %}
  default.conf.template: |
{% for line in frontend_nginx_template.split('\n') %}
    {{ line }}
{% endfor %}
  30-render-config.sh: |
{% for line in frontend_entrypoint_script.split('\n') %}
    {{ line }}
{% endfor %}
---
apiVersion: v1
kind: ConfigMap
metadata:
  name: {{ project.name }}-{{ selected_env }}-backend-source
  namespace: {{ target.namespace }}
  labels:
    idea.rnen.kr/project: {{ project.name }}
    idea.rnen.kr/environment: {{ selected_env }}
data:
  package.json: |
{% for line in backend_package_json.split('\n') %}
    {{ line }}
{% endfor %}
  db.js: |
{% for line in backend_db_js.split('\n') %}
    {{ line }}
{% endfor %}
  server.js: |
{% for line in backend_server_js.split('\n') %}
    {{ line }}
{% endfor %}
---
apiVersion: v1
kind: PersistentVolumeClaim
metadata:
  name: db-data
  namespace: {{ target.namespace }}
  labels:
    idea.rnen.kr/project: {{ project.name }}
    idea.rnen.kr/environment: {{ selected_env }}
spec:
  accessModes:
    - ReadWriteOnce
  resources:
    requests:
      storage: {{ db_storage_size }}
---
apiVersion: apps/v1
kind: Deployment
metadata:
  name: db
  namespace: {{ target.namespace }}
  labels:
    app.kubernetes.io/name: db
    idea.rnen.kr/project: {{ project.name }}
    idea.rnen.kr/environment: {{ selected_env }}
spec:
  replicas: 1
  selector:
    matchLabels:
      app.kubernetes.io/name: db
      idea.rnen.kr/project: {{ project.name }}
      idea.rnen.kr/environment: {{ selected_env }}
  template:
    metadata:
      labels:
        app.kubernetes.io/name: db
        idea.rnen.kr/project: {{ project.name }}
        idea.rnen.kr/environment: {{ selected_env }}
    spec:
      containers:
        - name: postgres
          image: postgres:16-alpine
          imagePullPolicy: IfNotPresent
          env:
            - name: POSTGRES_DB
              value: {{ postgres_db | tojson }}
            - name: POSTGRES_USER
              value: {{ postgres_user | tojson }}
            - name: POSTGRES_PASSWORD
              valueFrom:
                secretKeyRef:
                  name: {{ project.name }}-{{ selected_env }}-runtime-secrets
                  key: POSTGRES_PASSWORD
          ports:
            - containerPort: 5432
              name: postgres
          readinessProbe:
            exec:
              command:
                - sh
                - -c
                - pg_isready -U "$POSTGRES_USER" -d "$POSTGRES_DB"
            initialDelaySeconds: 10
            periodSeconds: 10
          livenessProbe:
            exec:
              command:
                - sh
                - -c
                - pg_isready -U "$POSTGRES_USER" -d "$POSTGRES_DB"
            initialDelaySeconds: 20
            periodSeconds: 20
          volumeMounts:
            - name: db-data
              mountPath: /var/lib/postgresql/data
      volumes:
        - name: db-data
          persistentVolumeClaim:
            claimName: db-data
---
apiVersion: v1
kind: Service
metadata:
  name: db
  namespace: {{ target.namespace }}
  labels:
    app.kubernetes.io/name: db
    idea.rnen.kr/project: {{ project.name }}
    idea.rnen.kr/environment: {{ selected_env }}
spec:
  selector:
    app.kubernetes.io/name: db
    idea.rnen.kr/project: {{ project.name }}
    idea.rnen.kr/environment: {{ selected_env }}
  ports:
    - name: postgres
      port: 5432
      targetPort: postgres
---
apiVersion: apps/v1
kind: Deployment
metadata:
  name: backend
  namespace: {{ target.namespace }}
  labels:
    app.kubernetes.io/name: backend
    idea.rnen.kr/project: {{ project.name }}
    idea.rnen.kr/environment: {{ selected_env }}
spec:
  replicas: 1
  selector:
    matchLabels:
      app.kubernetes.io/name: backend
      idea.rnen.kr/project: {{ project.name }}
      idea.rnen.kr/environment: {{ selected_env }}
  template:
    metadata:
      labels:
        app.kubernetes.io/name: backend
        idea.rnen.kr/project: {{ project.name }}
        idea.rnen.kr/environment: {{ selected_env }}
    spec:
      initContainers:
        - name: install-deps
          image: node:20-alpine
          imagePullPolicy: IfNotPresent
          command:
            - sh
            - -lc
            - |
              cp /src/package.json /work/package.json
              cp /src/db.js /src/server.js /work/
              cd /work
              npm install --omit=dev
          volumeMounts:
            - name: backend-source
              mountPath: /src
            - name: backend-work
              mountPath: /work
      containers:
        - name: backend
          image: node:20-alpine
          imagePullPolicy: IfNotPresent
          command:
            - sh
            - -lc
            - |
              cd /app
              node server.js
          env:
            - name: PORT
              value: "8080"
{% for key, value in runtime_env | dictsort %}
            - name: {{ key }}
              value: {{ value | tojson }}
{% endfor %}
{% for key in runtime_secret_keys %}
            - name: {{ key }}
              valueFrom:
                secretKeyRef:
                  name: {{ project.name }}-{{ selected_env }}-runtime-secrets
                  key: {{ key }}
{% endfor %}
          ports:
            - containerPort: 8080
              name: http
          readinessProbe:
            httpGet:
              path: /api/readyz
              port: http
            initialDelaySeconds: 10
            periodSeconds: 10
          livenessProbe:
            httpGet:
              path: /api/healthz
              port: http
            initialDelaySeconds: 20
            periodSeconds: 20
          volumeMounts:
            - name: backend-work
              mountPath: /app
      volumes:
        - name: backend-source
          configMap:
            name: {{ project.name }}-{{ selected_env }}-backend-source
        - name: backend-work
          emptyDir: {}
---
apiVersion: v1
kind: Service
metadata:
  name: backend
  namespace: {{ target.namespace }}
  labels:
    app.kubernetes.io/name: backend
    idea.rnen.kr/project: {{ project.name }}
    idea.rnen.kr/environment: {{ selected_env }}
spec:
  selector:
    app.kubernetes.io/name: backend
    idea.rnen.kr/project: {{ project.name }}
    idea.rnen.kr/environment: {{ selected_env }}
  ports:
    - name: http
      port: 8080
      targetPort: http
---
apiVersion: apps/v1
kind: Deployment
metadata:
  name: frontend
  namespace: {{ target.namespace }}
  labels:
    app.kubernetes.io/name: frontend
    idea.rnen.kr/project: {{ project.name }}
    idea.rnen.kr/environment: {{ selected_env }}
spec:
  replicas: 1
  selector:
    matchLabels:
      app.kubernetes.io/name: frontend
      idea.rnen.kr/project: {{ project.name }}
      idea.rnen.kr/environment: {{ selected_env }}
  template:
    metadata:
      labels:
        app.kubernetes.io/name: frontend
        idea.rnen.kr/project: {{ project.name }}
        idea.rnen.kr/environment: {{ selected_env }}
    spec:
      initContainers:
        - name: prepare-frontend
          image: busybox:1.36
          command:
            - sh
            - -lc
            - |
              cp /src/index.html /www/index.html
              cp /src/app.js /www/app.js
              cp /src/config.js.template /www/config.js.template
              cp /src/default.conf.template /config/default.conf.template
              cp /src/30-render-config.sh /entrypoint/30-render-config.sh
              chmod +x /entrypoint/30-render-config.sh
          volumeMounts:
            - name: frontend-source
              mountPath: /src
            - name: frontend-www
              mountPath: /www
            - name: frontend-config
              mountPath: /config
            - name: frontend-entrypoint
              mountPath: /entrypoint
      containers:
        - name: frontend
          image: nginx:1.27-alpine
          imagePullPolicy: IfNotPresent
          env:
{% for key, value in frontend_env | dictsort %}
            - name: {{ key }}
              value: {{ value | tojson }}
{% endfor %}
          ports:
            - containerPort: 80
              name: http
          readinessProbe:
            httpGet:
              path: /
              port: http
            initialDelaySeconds: 5
            periodSeconds: 10
          livenessProbe:
            httpGet:
              path: /
              port: http
            initialDelaySeconds: 15
            periodSeconds: 20
          volumeMounts:
            - name: frontend-www
              mountPath: /usr/share/nginx/html
            - name: frontend-config
              mountPath: /etc/nginx/templates
            - name: frontend-entrypoint
              mountPath: /docker-entrypoint.d
      volumes:
        - name: frontend-source
          configMap:
            name: {{ project.name }}-{{ selected_env }}-frontend-assets
        - name: frontend-www
          emptyDir: {}
        - name: frontend-config
          emptyDir: {}
        - name: frontend-entrypoint
          emptyDir: {}
---
apiVersion: v1
kind: Service
metadata:
  name: frontend
  namespace: {{ target.namespace }}
  labels:
    app.kubernetes.io/name: frontend
    idea.rnen.kr/project: {{ project.name }}
    idea.rnen.kr/environment: {{ selected_env }}
spec:
  selector:
    app.kubernetes.io/name: frontend
    idea.rnen.kr/project: {{ project.name }}
    idea.rnen.kr/environment: {{ selected_env }}
  ports:
    - name: http
      port: 80
      targetPort: http
  type: LoadBalancer
